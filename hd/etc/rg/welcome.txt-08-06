%define;display_sosa_ref(xx)
  [*Sosa reference: %t:::xx]
%end;

<div id="content">
  <div id="search">
    <h3 class="with_picto" style=" background-image:url(%image_prefix;/picto_loupe.png)"> [*search/case sensitive]0</h3>
      <form id="form-person" method="get" action="%action;">
      <fieldset>
        <div id="content">
          %hidden;
          <input type="hidden" name="m" value="S"%/>
          <span class="highlight">[person/persons]0</span>
          <br%/>
          <input type="text" name="n" placeholder="[*first name/first names]0 [surname/surnames]0, [*surname/surnames]0, [*public name], [*alias] %if;browsing_with_sosa_ref;, [n° Sosa relative to]%end; ..." size="77" maxlength="200" autofocus%/>
          <input type="submit" value="Ok"%/><br%/>
          <input type="text" name="p" placeholder="[*first name/first names]0" size="35" maxlength="200"%/>
          %if;browsing_with_sosa_ref;%apply;display_sosa_ref%with;%sosa_ref;%end;%end;
        </div>
      </fieldset>
      </form>

      <form id="form-person" method="get" action="%action;">
      <fieldset>
	<table>
	<tr>
	<td>
        <div id="content">
          %hidden;
          <input type="hidden" name="m" value="NG"%/>
          <span class="highlight">[family/families]0</span>
          <br%/>
          <input type="text" name="sn" placeholder="[*surname/surnames]0" %/>
        </div>
	</td>
        <td>
        <div id="content">
          %hidden;
          <input type="hidden" name="m" value="NG"%/>
          <span class="highlight">[alias]0</span>
          <br%/>
          <input type="text" name="n" placeholder="[*alias]0" %/>
          <input type="submit" value="Ok"%/><br%/>
        </div>
        </td>
        </tr>
      </table>
      </fieldset>
      </form>

      %if;(bvar.propose_titles != "no")%nl;
        <form id="form-titles" method="get" action="%action;">
        <fieldset>
            <div>
             %hidden;
            <input type="hidden" name="m" value="TT"%/>
              <label class="legend"><span class="highlight">[title/titles]0</span><br%/>
                <input name="t" size="35" maxlength="200"%/>
              </label><br%/>
                <a href="%prefix;m=TT;t=">([all the titles])</a>
            </div>
            <div>
              <label class="legend"><span class="highlight">[estate]0</span><br%/>
                <input name="p" size="35" maxlength="200"%/>%sq;
              </label>
              <input type="submit" value="Ok"%/>
              <br%/>
              <a href="%prefix;m=TT;p=*">([all the estates])</a>
            </div>
        </fieldset>
        </form>
     %end;
      <form id="form-all-names" method="get" action="%action;">
      <fieldset>
        <div>
          %hidden;
          <span class="highlight">[list/list (ancestors)]</span>
          <select name="m">
            <option value="N" selected="selected">[surname/surnames]1</option>
            <option value="P">[first name/first names]1</option>
          </select>
[
af: volgens
bg: ,&nbsp; подредени по
br: dre
ca: per
cs: seřazená podle
da: sorteret efter
de: durch
en: by
eo: laù
es: por
et: järjestatud
fi: lajiteltuina
fr: par
fr-cr: zott pé trappé assou liste-la
he: לפי
