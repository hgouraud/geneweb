%doctype;
<html xmlns="http://www.w3.org/1999/xhtml">
%let;basecap;%apply;capitalize(base.name)%in;
%let;basetitle;<span class="basetitle">%basecap;</span>%in;
<head>
  <!-- $Id: welcome.txt,v 1.40 2018-07-08 07:22:40 hg Exp $ -->
  <!-- Copyright (c) 2006-2012 -->
  <title>[
af: Genealogie/Familiekunde
bg: Genealogy
br: Genealogiezh
ca: Genealogia
cs: Genealogy
da: Genealogi
de: Genealogie
en: Genealogy
eo: Genealogio
es: Genealogía
et: Genealoogia
fi: Genealogia
fr: Généalogie adaptée au RGPD
he: תולדות
is: Ættfræði
it: Genealogia
lv: Ģenealoģija
nl: Genealogie
no: Genealogi
pl: Genealogia
pt: Genealogia
ro: Genealogie
ru: Genealogy
sl: Genealogija - Družinsko drevo
sv: Genealogi
] - %basecap;</title>
  <meta http-equiv="Content-Type" content="text/html; charset=%charset;"%/>
  <meta http-equiv="Content-Style-Type" content="text/css"%/>
  <meta name="robots" content="none"%/>
%base_header;
<style type="text/css">
  span.highlight { color:%highlight;; font-weight:bold }
  #user-info { float:%right; }
  #title { padding-top:1em }
  #title { text-align: enter; vertical-align:middle; width:100%% }
  #title { color:%highlight; }
  #lang { text-align:center }
  #lang .title { font-size:80%% }
  #lang .list { width:100%% }
  #lang a { display: inline }
  #lang .item span { display:none }
  #content .subtitle { text-align:center }
  .with_picto { background-repeat:no-repeat; background-position:left center; padding: 4px 4px 4px 20px; }
  #form-person input { margin:3px 3px 1px 3px;}
  #form-titles input { margin:2px 3px 2px 3px; }
  #form-all-names select { margin:0px 3px 0px 3px; width:188px;}
</style>
</head>
<body>
<script type="text/javascript">
<!--
var zgw_image_prefix = "%image_prefix;";
var zgw_base = '%base.name;';
var zgw_size = "%base.nb_persons;";
var zgw_lang = "%evar.lang;";
var zgw_user_name = "%user.name;";
var zgw_sosa_ref = "%bvar.supervisor;";
-->
</script>

<script type="text/javascript"><!--
  function WorkOnBrowser() {
    if (navigator.appVersion.substring(0,3) >= 3.0 &&
        navigator.appName == 'Netscape' ||
        navigator.appVersion.substring(0,3) >= 4.0 &&
        navigator.appName.substring(0,9) == 'Microsoft') return true;
    else return false;
  }
  // -->
</script>

%define;book_of(xx)
  [*book of %s:::xx]
%end;

%define;msg_lang_style(xx,yy,zz)
%if;(bvar.yy_xx != "")
  <div zz>%bvar.yy_xx</div>
%else;
  %if;(bvar.yy != "")
    <div zz>%bvar.yy</div>
  %end;
%end;
%end;

%define;msg_lang_link(xx,yy)
%if;(bvar.yy_xx != "")
  %if;(bvar.yy_lnk != "")<a href="%bvar.yy_lnk;">%end;
  %if;(bvar.yy_not != "")<a href="%prefix;m=NOTES;f=%bvar.yy_not;">%end;
  %bvar.yy_xx
  %if;(bvar.yy_lnk != "" or bvar.yy_not != "")</a>%end;
%else;
  %if;(bvar.yy != "")
  %if;(bvar.yy_not != "")<a href="%prefix;m=NOTES;f=%bvar.yy_not;">%end;
  %if;(bvar.yy_lnk != "")<a href="%bvar.yy_lnk;">%end;
  %bvar.yy
  %if;(bvar.yy_lnk != "" or bvar.yy_not != "")</a>%end;
  %end;
%end;
%end;


%define;language_link(xx,yy)%sq;
  %let;zz;%if;("yy" = "")xx%else;xx-yy%end;%in;%sq;
  %let;tt;%if;("yy" = "")xx%else;xx_yy%end;%in;%sq;
  <a href="%prefix_base;lang=%zz;%if;(evar.templ != "");templ=%evar.templ;%end;">
  <img src="%image_prefix;/flags/l-%zz;.jpg" id="i%tt;" width="36" height="22"
  class="item" title="%apply;language_name(zz)" alt="%apply;language_name(zz)"
  onmouseover="if (WorkOnBrowser())%sp;%sq; i%tt;.src='%image_prefix;/flags/t-xx.png'"
  onmouseout="i%tt;.src='%image_prefix;/flags/l-%zz;.jpg'"%/></a>
%end;

  %( Display the acces bloc if there is  %)
  %( a password or an empty block if not %)
  %if; (bvar.wizard_passwd != "" or bvar.wizard_passwd_file != ""
        or bvar.friend_passwd != "" or bvar.friend_passwd_file != "")
    <div id="acces">
      <h3><img src="%image_prefix;/picto_cle.png" alt="login" />[*access] :</h3>
      %if;(not wizard and (bvar.wizard_passwd != "" or bvar.wizard_passwd_file != ""))
        %if;(not cgi and bvar.auth_file = "")
          <a href="%prefix;w=w"><em>%sq;
          [wizard/wizards/friend/friends/exterior]0</em></a><br%/>
        %else;
          <form method="post" action="%action;?b=%base.name;">
            <div>
              %hidden;
              [*user/password/cancel]1 ([wizard/wizards/friend/friends/exterior]0) :
              <input name="w" type="password" size="10" maxlength="200"%/>
              <input type="submit" value="Ok"%/>
            </div>
          </form>
        %end;
      %end;
      %if;(not friend and (bvar.friend_passwd != "" or bvar.friend_passwd_file != ""))
        %if;(not cgi and bvar.auth_file = "")
          <a href="%prefix;w=f"><em>%sq;
          [wizard/wizards/friend/friends/exterior]2</em></a><br%/>
        %end;
      %end;
      %if;(wizard
           and (bvar.wizard_passwd != "" or bvar.wizard_passwd_file != ""))
        <em>[wizard/wizards/friend/friends/exterior]0%sq;
        %if;(user.name != "") : <a href="%prefix;m=WIZNOTES;f=%user.ident;">%user.name;</a>%sq;
        %else;
         %if;(user.ident != "") : <a href="%prefix;m=WIZNOTES;f=%user.ident;">%user.ident;</a>%sq;
        %end;
        %end;</em>
        (<a href="%prefix;w=">[disconnect]</a>)
      %end;
      %if;(friend and (bvar.friend_passwd != "" or bvar.friend_passwd_file != ""))
        <em>[wizard/wizards/friend/friends/exterior]2
        %if;(user.name != "") : <a href="%prefix;;m=NG;n=%user.name;">%user.name;</a>%sq;
        %else;
        %if;(user.ident != "") : %user.ident; %end;
        %end;</em>
        (<a href="%prefix;w=">[disconnect]</a>)
      %end;
    </div>
  %else
    <div id="acces"></div>
  %end;


